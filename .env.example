# Private wallet / deployment config; keep real values in ignored .env files only
PRIVATE_KEY=0xYOUR_PRIVATE_KEY
SPONSOR_PRIVATE_KEY=0xYOUR_SPONSOR_PRIVATE_KEY
ETHERSCAN_API_KEY=
CELOSCAN_API_KEY=

# Server-side RPC endpoints for Hardhat and scripts
CELO_MAINNET_RPC_URL=https://forno.celo.org
CELO_SEPOLIA_RPC_URL=https://forno.celo-sepolia.celo-testnet.org

# Public frontend contract address config
NEXT_PUBLIC_NOODL3_CONTRACT_ADDRESS_MAINNET=
NEXT_PUBLIC_NOODL3_CONTRACT_ADDRESS_SEPOLIA=
# Optional deployment block hints help deployment tracking and event lookups start at the contract launch.
NEXT_PUBLIC_NOODL3_CONTRACT_DEPLOYMENT_BLOCK_MAINNET=
NEXT_PUBLIC_NOODL3_CONTRACT_DEPLOYMENT_BLOCK_SEPOLIA=

# Script-only contract address config
NOODL3_CONTRACT_ADDRESS_MAINNET=
NOODL3_CONTRACT_ADDRESS_SEPOLIA=
# Public app config
# Used as the base URL for shared QR links and generated social metadata.
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Use celoSepolia for testing and celo for production.
NEXT_PUBLIC_DEFAULT_CHAIN=celoSepolia
# Browser-visible RPC fallbacks; keep private or metered endpoints in the non-public RPC vars.
NEXT_PUBLIC_CELO_MAINNET_RPC_URL=https://forno.celo.org
NEXT_PUBLIC_CELO_SEPOLIA_RPC_URL=https://forno.celo-sepolia.celo-testnet.org
